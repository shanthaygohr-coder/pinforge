{
  "name": "pinforge",
  "version": "0.1.0",
  "description": "SaaS pentru automatizarea marketingului afiliat pe Pinterest (AI generativ + conformitate FTC + rate-limit + scheduling autonom).",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^5.20.0",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.4",
    "@types/node": "^22.5.0",
    "prisma": "^5.20.0",
    "typescript": "^5.6.0"
  }
}
