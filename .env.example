# ---- Baza de date (PostgreSQL gratuit: Supabase / Neon) ----
DATABASE_URL="postgresql://user:pass@localhost:5432/pinforge?schema=public"

# ---- Criptare tokenuri (AES-256-GCM). Foloseste o cheie aleatoare lunga! ----
ENCRYPTION_KEY="change-me-to-a-long-random-secret"

# ---- Secret pentru endpoint-ul de cron (il pui si in cron-job.org) ----
CRON_SECRET="change-me-to-a-random-string"

# ---- Pinterest OAuth 2.0 (Authorization Code Grant) ----
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
PINTEREST_REDIRECT_URI="https://your-host/pinterest/callback"

# Nota: NU mai e nevoie de Redis in varianta gratuita (publicare prin cron).
