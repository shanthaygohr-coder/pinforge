# ---- Baza de date / coada ----
DATABASE_URL="postgresql://user:pass@localhost:5432/pinforge?schema=public"
REDIS_URL="redis://localhost:6379"

# ---- Criptare tokenuri (AES-256-GCM). Foloseste o cheie aleatoare lunga! ----
ENCRYPTION_KEY="change-me-to-a-long-random-secret"

# ---- Pinterest OAuth 2.0 (Authorization Code Grant) ----
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
PINTEREST_REDIRECT_URI="https://app.exemplu.com/api/pinterest/callback"

# ---- Stable Diffusion (SDXL) ----
SD_API_URL="https://api.stability.ai/v2beta/stable-image/generate/sdxl"
SD_API_KEY=""

# ---- LLM pentru copy (NLP) ----
LLM_API_URL="https://api.openai.com/v1/chat/completions"
LLM_API_KEY=""
LLM_MODEL="gpt-4o-mini"

# ---- Storage creative (S3 / Cloudflare R2) ----
S3_ENDPOINT=""
S3_BUCKET="pinforge-creatives"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
